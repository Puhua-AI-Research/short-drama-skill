# 复制为 .env 并填入密钥（不要将 .env 提交到 Git）
# ph8_generate_image.py / ph8_generate_video.py 会自动读取「项目根目录」下的 .env
PH8_API_KEY=your-api-key-here

# 可选：兼容 OpenAI 生态的变量名
# OPENAI_API_KEY=your-api-key-here

# 图像 API Base（二选一，默认 openai 前缀）
OPENAI_BASE_URL=https://ph8.co/openai/v1
# OPENAI_BASE_URL=https://ph8.co/v1

# 可选：默认生图模型
# PH8_IMAGE_MODEL=Nano-Banana-Pro2

# 可选：默认视频模型
# PH8_VIDEO_MODEL=doubao-seedance-1-5-pro-251215
